{
  "crons": [
    {
      "path": "/api/interview/cleanup",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "api/article/[slug].ts": {
      "maxDuration": 10
    },
    "api/prerender/[...path].ts": {
      "maxDuration": 10
    },
    "api/sitemap.ts": {
      "maxDuration": 30
    },
    "api/auth/verify.ts": {
      "maxDuration": 5
    },
    "api/subscribe.ts": {
      "maxDuration": 10
    },
    "api/interview/generate.ts": {
      "maxDuration": 15
    },
    "api/interview/notify.ts": {
      "maxDuration": 10
    },
    "api/interview/cleanup.ts": {
      "maxDuration": 30
    },
    "api/reco/enrich.ts": {
      "maxDuration": 10
    },
    "api/reco/submit.ts": {
      "maxDuration": 10
    }
